# stablecoin_arbi — environment overrides. Copy to .env (optional).
# The dryrun tool + backtests need NO secrets here.

# ── dryrun target (overrides config/strategy.yaml without editing it) ──
# SYMBOL=USD1USDT
# SECONDS=86400        # run length per cycle (604800 = 7 days)
# DASHBOARD_PORT=3005  # web dashboard port (docker compose --profile dryrun)

# ── path overrides (normally set by the Docker image; only for bare-metal) ──
# SCA_CONFIG=/app/config/strategy.yaml
# SCA_DATA_DIR=/app/data
# SCA_OUT_DIR=/app/out

# ── Future live trading (NOT implemented — placeholders only) ──
# BYBIT_API_KEY=
# BYBIT_API_SECRET=
