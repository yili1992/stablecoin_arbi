# stablecoin_arbi — .env (copy this to .env; OPTIONAL). git-ignored.
#
# All NON-SECRET launch config now lives in ONE place: config/strategy.yaml `runtime:`
# (symbol / seconds / mode / dashboard_port / out_dir). Edit the yaml, not env vars.
# This file is ONLY for: (a) secrets, (b) a few deploy/env overrides below.
# The default PAPER engine, dryrun tool, and backtests need NOTHING here.

# ── deploy/env overrides (not app config) ──
# DASHBOARD_PORT=3015   # HOST port the docker dashboard is published on (container stays runtime.dashboard_port)
# SCA_OUT_DIR=/app/out  # status/csv/state dir (docker sets this; bare-metal override only)
# SCA_DATA_DIR=/app/data
# SCA_CONFIG=/app/config/strategy.yaml   # path to the yaml itself (must be env — it can't live inside itself)

# ── LIVE TRADING ONLY — real orders, real money. USE AT YOUR OWN RISK. ──
#    Leave unset for paper (the default). The engine places real orders ONLY when
#    mode==live AND LIVE_TRADING_CONFIRM=="yes" AND both keys are set; else it refuses.
#    `MODE=live` here is how docker/bare-metal selects live without editing the yaml.
#    Uncomment + fill ALL FOUR to go live:
# MODE=live
# LIVE_TRADING_CONFIRM=yes
# BYBIT_API_KEY=
# BYBIT_API_SECRET=
