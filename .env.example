# stablecoin_arbi — environment overrides. Copy to .env (optional).
# The default PAPER engine, dryrun tool, and backtests need NO secrets here.

# ── paper / live engine target (overrides config/strategy.yaml without editing it) ──
# SYMBOL=USD1USDT
# SECONDS=604800       # run length per cycle in seconds (604800 = 7 days)
# DASHBOARD_PORT=3015  # web dashboard port

# ── path overrides (normally set by the Docker image; only for bare-metal) ──
# SCA_CONFIG=/app/config/strategy.yaml
# SCA_DATA_DIR=/app/data
# SCA_OUT_DIR=/app/out

# ── LIVE TRADING ONLY — real orders, real money. USE AT YOUR OWN RISK. ──
#    Leave these unset for paper (the default). The engine will ONLY place real
#    orders when mode==live AND LIVE_TRADING_CONFIRM=="yes" AND both keys are set;
#    otherwise it refuses to trade. Uncomment + fill ALL FOUR to go live:
# MODE=live
# LIVE_TRADING_CONFIRM=yes
# BYBIT_API_KEY=
# BYBIT_API_SECRET=
